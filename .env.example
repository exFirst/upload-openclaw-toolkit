# ============================================
# Zipline Configuration Example
# Copy to .env and fill in your values
# ============================================

# --- Required (generate both with: openssl rand -base64 42 | tr -dc A-Za-z0-9 | cut -c -32) ---
CORE_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHARS
POSTGRESQL_PASSWORD=CHANGE_ME_TO_A_RANDOM_32_CHARS

# --- Core ---
CORE_PORT=3000
# CORE_HOSTNAME=0.0.0.0

# --- Domain (uncomment and set your domain) ---
# CORE_RETURN_HTTPS_URLS=true
# CORE_DEFAULT_DOMAIN=zipline.example.com
# CORE_TRUST_PROXY=true

# --- Datasource: Local (default) ---
DATASOURCE_TYPE=local
DATASOURCE_LOCAL_DIRECTORY=./uploads

# --- OR Datasource: S3 (Cloudflare R2, Backblaze B2, Minio) ---
# DATASOURCE_TYPE=s3
# DATASOURCE_S3_ACCESS_KEY_ID=your-key
# DATASOURCE_S3_SECRET_ACCESS_KEY=your-secret
# DATASOURCE_S3_BUCKET=zipline
# DATASOURCE_S3_REGION=us-east-1
# DATASOURCE_S3_ENDPOINT=https://your-endpoint.com
# DATASOURCE_S3_FORCE_PATH_STYLE=true

# --- Files ---
FILES_ROUTE=/u
FILES_LENGTH=6
FILES_MAX_FILE_SIZE=100mb
FILES_DEFAULT_EXPIRATION=30d
FILES_REMOVE_GPS_METADATA=true

# --- URL Shortener ---
URLS_ROUTE=/go
URLS_LENGTH=6

# --- Features ---
FEATURES_IMAGE_COMPRESSION=true
FEATURES_THUMBNAILS_ENABLED=true
FEATURES_USER_REGISTRATION=true
FEATURES_DELETE_ON_MAX_VIEWS=true

# --- Chunks (large file uploads) ---
CHUNKS_ENABLED=true
CHUNKS_SIZE=25mb
CHUNKS_MAX=95mb
